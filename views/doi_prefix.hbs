<!DOCTYPE html>
<html lang="en-US">
{{>head}}
<body>
{{>header}}
<a href="#main-content" class="visually-hidden">skip to main content</a>
<nav>
<ul>
<li><a href="/" title="return home">All Library Apps</a></li>
<li><a href="../" title="return to dashboard">Dashboard</a></li>
<li><a href="./" title="return to doi_prefix list">DOI Prefixs</a></li>
<li><a href="{{doi_prefix.doi_prefix}}?view=edit">Edit {{doi_prefix.doi_prefix}}</a></li>
</ul>
</nav>
<section id="main-content">

<h1>{{doi_prefix.name}}</h1>
<div class="identifier">https://doi.org/{{doi_prefix.doi_prefix}}</div>

{{#if doi_prefix.description}}<div class="description">{{doi_prefix.description}}</div>{{/if}}

<div class="labeled_dates">
{{#if doi_prefix.updated}}<span class="updated">updated: {{doi_prefix.updated}}</span>{{/if}}
</div>


<p>
</section>
{{>footer}}
<!-- <code><pre>{{debug_src}}</pre></code> -->
</body>
</html>
