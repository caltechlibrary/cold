<script>
(function() {
  const sel = document.getElementById('report_name');
  const fields = document.getElementById('collaborator-fields');
  const orcidRow = document.getElementById('orcid-row');
  const countryFields = document.getElementById('country-fields');
  const clpidInput = document.getElementById('clpid');
  const orcidInput = document.getElementById('orcid');
  const countrySelect = document.getElementById('country_code');
  const countryNameInput = document.getElementById('country_name');
  const form = document.getElementById('report-request-form');
  let populated = false;

  function update() {
    const isCollab = sel.value === 'run_collaborator_report';
    const isAffil = sel.value === 'run_collaborator_affiliations_report';
    const isPubs = sel.value === 'run_publications_by_person_identifiers';
    const isCountry = sel.value === 'run_country_collaboration_report';
    const needsPersonFields = isCollab || isAffil || isPubs;

    fields.style.display = needsPersonFields ? '' : 'none';
    orcidRow.style.display = isPubs ? '' : 'none';
    countryFields.style.display = isCountry ? '' : 'none';
    clpidInput.required = isCollab || isAffil;
    orcidInput.required = false;

    if (needsPersonFields && !populated) {
      populated = true;
      fetch('./api/people.ds/get_all_clpid')
        .then(r => r.json())
        .then(list => {
          const dl = document.getElementById('clpid-list');
          list.forEach(id => {
            const opt = document.createElement('option');
            opt.value = id;
            dl.appendChild(opt);
          });
        });
    }

  }

  function applyCountrySelection() {
    const opt = countrySelect.options[countrySelect.selectedIndex];
    countryNameInput.value = opt ? (opt.dataset.filename || '') : '';
  }
  countrySelect.addEventListener('change', applyCountrySelection);

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    if (sel.value === 'run_publications_by_person_identifiers') {
      if (!clpidInput.value.trim() && !orcidInput.value.trim()) {
        alert('Please provide at least one of CLPID or ORCID before submitting this report.');
        return;
      }
    }
    if (sel.value === 'run_country_collaboration_report') {
      const cc = countrySelect.value.trim();
      if (!cc || !/^[A-Z]{2}$/.test(cc)) {
        alert('Please select a country from the list before submitting this report.');
        return;
      }
    }
    var body = new URLSearchParams(new FormData(form));
    fetch('./reports', {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      body: body
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.ok && data.id) {
          window.refreshReportList();
          window.pollReport(data.id);
        } else {
          window.refreshReportList();
        }
      })
      .catch(function() { window.refreshReportList(); });
  });

  sel.addEventListener('change', update);
  update();
})();
</script>

