  window.refreshReportList = function() {
    fetch('./reports')
      .then(function(r) { return r.text(); })
      .then(function(html) {
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var newTable = doc.getElementById('report-list-table');
        var curTable = document.getElementById('report-list-table');
        if (newTable && curTable) {
          curTable.innerHTML = newTable.innerHTML;
        }
      });
  };

  window.pollReport = function(id) {
    clearTimeout(reportPollTimer);
    reportPollTimer = setTimeout(function() {
      fetch('./api/reports.ds/get_report?id=' + encodeURIComponent(id))
        .then(function(r) { return r.json(); })
        .then(function(rows) {
          var row = Array.isArray(rows) ? rows[0] : null;
          var status = row ? (row.status || '').toLowerCase() : '';
          if (status === 'completed' || status === 'error') {
            window.refreshReportList();
          } else {
            window.refreshReportList();
            window.pollReport(id);
          }
        })
        .catch(function() { window.pollReport(id); });
    }, 15000);
  };
})();
</script>
</section>
{{>footer}}
</body>
</html>
