<!DOCTYPE html>
<html lang="en-US">
{{>head}}
<body>
{{>header}}
<a href="#main-content" class="visually-hidden">skip to main content</a>
<nav>
<ul>
<li><a href="/" title="return home">All Library Apps</a></li>
<li><a href="./" title="return to dashboard">Dashboard</a></li>
<li><a href="reports" title="Refresh reports list">Reports</a></li>
</ul>
</nav>
<section id="main-content">
<h1>Request a Report</h1>

<form id="report-request-form" action="{{report_queue.id}}" method="post">

<div>
<label set="report_name">Report</label>
<select name="report_name" id="report_name">
  <hr />
  <optgroup label="CSV reports">
    <option value="run_people_csv" title="This is a dump of the People collection">Generate People CSV File</option>
    <option value="run_groups_csv" title="This is a dump of the Groups collection">Generate Groups CSV File</option>
    <option value="run_people_identifier_csv" title="This CSV file holds both people names and identifiers">Generate People Identifier CSV</option>
    <option value="run_division_people_csv" title="This report is based on content from campus directory">Generate a Division People CSV</option>
    <option value="run_people_membership_csv" title="This report shows library assigned group membership">Generate a People Membership CSV</option>
    <option value="run_division_people_crosswalk_csv" title="This report crosswalks people and the campus directory division info">Generate Division People Crosswalk CSV</option>
    <option value="run_group_people_crosswalk_csv" title="This report crosswalks people in groups">Generate Group People Crosswalk CSV</option>
    <option value="run_thesis_options_csv" title="This report delivers a list of thesis option names and ids">Generate Thesis Options CSV</option>
  </optgroup>

  <hr />
  <optgroup label="RDM Records and Review Queue">
    <option value="run_authors_records_csv" title="This is a report from the both subbmitted and accepted requests">Generate Authors' Records CSV File</option>
    <option value="run_authors_review_queue_csv" title="This is a report from only the review queue requests">Generate Authors' Review Queue CSV File</option>
  </optgroup>

  <hr />
  <optgroup label="RDM Vocabularies">
    <option value="journal_vocabulary">Generate Journals Vocabulary</option>
    <option value="thesis_option_vocabulary" title="Generate Thesis options">Generate Thesis Option Vocabulary</option>
    <option value="group_vocabulary" title="Generate RDM groups vocabulary">Generate Groups Vocabulary</option>
    <option value="people_vocabulary" title="Generate RDM people vocabulary">Generate People Vocabulary</option>
  </optgroup>

  <optgroup label="Mediated reports">
    <option value="run_collaborator_report" title="Run a colaborator report with a clpid">Collaborator Report</option>
    <option value="run_collaborator_affiliations_report" title="Run a collaborator affiliations report with a clpid">Collaborator Affiliations Report</option>
    <option value="run_publications_by_person_identifiers" title="Run a publications report for a person using clpid and/or ORCID">Publications by Person Identifier</option>
    <option value="run_country_collaboration_report" title="Run a country collaboration report using an ISO 3166-1 alpha-2 country code">Country Collaboration Report</option>
  </optgroup>

</select>

<div id="collaborator-fields" style="display:none">
<label for="clpid">Person (clpid)</label>
<input type="text" id="clpid" name="clpid"
       placeholder="e.g. Doiel-R-S" list="clpid-list"
       autocomplete="on">
<datalist id="clpid-list"></datalist>
<div id="orcid-row" style="display:none">
<label for="orcid">ORCID</label>
<input type="text" id="orcid" name="orcid"
       placeholder="e.g. 0000-0003-0900-6903"
       pattern="[0-9]{4}-[0-9]{4}-[0-9]{4}-[0-9]{3}[0-9X]"
       title="ORCID format: NNNN-NNNN-NNNN-NNNN (last character may be X)">
</div>
</div>

<div id="country-fields" style="display:none">
<label for="country_name_display">Country</label>
<input type="text" id="country_name_display"
       placeholder="e.g. South Korea, Australia, Germany"
       list="country-name-list"
       autocomplete="country-name">
<datalist id="country-name-list"></datalist>
<input type="hidden" id="country_code" name="country_code">
<input type="hidden" id="country_name" name="country_name">
</div>

<label set="emails">Email notification(s)</label>
<input type="text" id="emails" name="emails" placeholder="rsdoiel@caltech.edu" />
<input type="submit" id="submit" name="submit" value="Request Report">
</div>

<script>
(function() {
  const sel = document.getElementById('report_name');
  const fields = document.getElementById('collaborator-fields');
  const orcidRow = document.getElementById('orcid-row');
  const countryFields = document.getElementById('country-fields');
  const clpidInput = document.getElementById('clpid');
  const orcidInput = document.getElementById('orcid');
  const countryCodeInput = document.getElementById('country_code');
  const countryNameInput = document.getElementById('country_name');
  const countryNameDisplay = document.getElementById('country_name_display');
  const form = document.getElementById('report-request-form');
  let populated = false;
  let countryPopulated = false;
  let countryMap = {};

  function update() {
    const isCollab = sel.value === 'run_collaborator_report';
    const isAffil = sel.value === 'run_collaborator_affiliations_report';
    const isPubs = sel.value === 'run_publications_by_person_identifiers';
    const isCountry = sel.value === 'run_country_collaboration_report';
    const needsPersonFields = isCollab || isAffil || isPubs;

    fields.style.display = needsPersonFields ? '' : 'none';
    orcidRow.style.display = isPubs ? '' : 'none';
    countryFields.style.display = isCountry ? '' : 'none';
    clpidInput.required = isCollab || isAffil;
    orcidInput.required = false;

    if (needsPersonFields && !populated) {
      populated = true;
      fetch('./api/people.ds/get_all_clpid')
        .then(r => r.json())
        .then(list => {
          const dl = document.getElementById('clpid-list');
          list.forEach(id => {
            const opt = document.createElement('option');
            opt.value = id;
            dl.appendChild(opt);
          });
        });
    }

    if (isCountry && !countryPopulated) {
      countryPopulated = true;
      fetch('./data/country_list.json')
        .then(r => r.json())
        .then(list => {
          const dl = document.getElementById('country-name-list');
          list.forEach(c => {
            const opt = document.createElement('option');
            opt.value = c.name;
            dl.appendChild(opt);
            countryMap[c.name] = { code: c.code, filename: c.filename };
          });
        });
    }
  }

  function applyCountrySelection() {
    const entry = countryMap[countryNameDisplay.value.trim()];
    if (entry) {
      countryCodeInput.value = entry.code;
      countryNameInput.value = entry.filename;
    } else {
      countryCodeInput.value = '';
      countryNameInput.value = '';
    }
  }
  countryNameDisplay.addEventListener('input', applyCountrySelection);
  countryNameDisplay.addEventListener('change', applyCountrySelection);

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    if (sel.value === 'run_publications_by_person_identifiers') {
      if (!clpidInput.value.trim() && !orcidInput.value.trim()) {
        alert('Please provide at least one of CLPID or ORCID before submitting this report.');
        return;
      }
    }
    if (sel.value === 'run_country_collaboration_report') {
      const cc = countryCodeInput.value.trim();
      if (!cc || !/^[A-Z]{2}$/.test(cc)) {
        alert('Please select a country from the list before submitting this report.');
        return;
      }
    }
    var body = new URLSearchParams(new FormData(form));
    fetch('./reports', {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      body: body
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.ok && data.id) {
          window.refreshReportList();
          window.pollReport(data.id);
        } else {
          window.refreshReportList();
        }
      })
      .catch(function() { window.refreshReportList(); });
  });

  sel.addEventListener('change', update);
  update();
})();
</script>

<!--
<div>
</div>
-->

</form>
<p>
(see <a href="report_descriptions.html" title="A detailed list of report names and function">Report Descriptions</a> for details.)
<p>
</section>
<hr>
<section>
<h1>Reports</h1>
<button onclick="window.refreshReportList()">Refresh List</button>
<table id="report-list-table">
  <tr>
    <th>Requested</th>
<!--    <th>Notify</th> -->
    <th>Report Name</th>
    <th>Status</th>
    <th>Link</th>
  </tr>
{{#report_list}}
  <tr>
    <td>{{requested}}</td>
<!--    <td>{{emails}}</td> -->
    <td>{{report_name}}</td>
    <td>{{status}}</td>
    <td>{{#if link}}<a href="{{link}}" target="_blank">{{link}}</a>{{/if}}</td>
  </tr>
{{/report_list}}
</table>
<script>
(function() {
  var reportPollTimer = null;

  window.refreshReportList = function() {
    fetch('./reports')
      .then(function(r) { return r.text(); })
      .then(function(html) {
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var newTable = doc.getElementById('report-list-table');
        var curTable = document.getElementById('report-list-table');
        if (newTable && curTable) {
          curTable.innerHTML = newTable.innerHTML;
        }
      });
  };

  window.pollReport = function(id) {
    clearTimeout(reportPollTimer);
    reportPollTimer = setTimeout(function() {
      fetch('./api/reports.ds/get_report?id=' + encodeURIComponent(id))
        .then(function(r) { return r.json(); })
        .then(function(rows) {
          var row = Array.isArray(rows) ? rows[0] : null;
          var status = row ? (row.status || '').toLowerCase() : '';
          if (status === 'completed' || status === 'error') {
            window.refreshReportList();
          } else {
            window.refreshReportList();
            window.pollReport(id);
          }
        })
        .catch(function() { window.pollReport(id); });
    }, 15000);
  };
})();
</script>
</section>
{{>footer}}
</body>
</html>
