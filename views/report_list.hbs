<!DOCTYPE html>
<html lang="en-US">
{{>head}}
<body>
{{>header}}
<a href="#main-content" class="visually-hidden">skip to main content</a>
<nav>
<ul>
<li><a href="/" title="return home">All Library Apps</a></li>
<li><a href="./" title="return to dashboard">Dashboard</a></li>
<li><a href="reports" title="Refresh reports list">Reports</a></li>
</ul>
